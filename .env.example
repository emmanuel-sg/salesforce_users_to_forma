# Example environment file for this repo.
#
# Copy to `.env` and fill in real values:
#   - On Windows PowerShell:  Copy-Item .env.example .env
#   - On macOS/Linux:         cp .env.example .env
#
# IMPORTANT: Never commit `.env` (it contains secrets). This repo's `.gitignore` ignores it.

# Comma-separated hub keys. Each key must have matching HUB_<key>_* variables below.
HUBS=swissgrid_dev

# ---- Hub: swissgrid_dev (example) ----
#
# Construction Admin account id (UUID). Used for:
# - hub roles / companies lookup
# - companyId / roleIds mapping
HUB_swissgrid_dev_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Data Management hub id (usually b.<uuid>). Used for:
# - listing projects via /project/v1/hubs/{hub_id}/projects
HUB_swissgrid_dev_DM_HUB_ID=b.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional display name used in CLI listings.
HUB_swissgrid_dev_NAME=TST

# APS app credentials (keep secret).
HUB_swissgrid_dev_CLIENT_ID=your_aps_client_id_here
HUB_swissgrid_dev_CLIENT_SECRET=your_aps_client_secret_here

# Needed for some Construction Admin calls when using a token without an embedded user.
# Prefer using the admin user id for the environment (TST vs PROD).
APS_USER_ID_TST=your_autodesk_user_id_here
# APS_USER_ID=your_autodesk_user_id_here

# 3-legged OAuth callback URL (must match what you configured in the APS app).
APS_REDIRECT_URI=http://127.0.0.1:8089/callback

# Space-separated scopes for APS OAuth.
APS_SCOPES=data:read data:write account:read account:write

# Optional: force client credentials flow (2-legged) instead of 3-legged.
# APS_AUTH_MODE=client_credentials

